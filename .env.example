# MiniHarness environment variables
# Copy this file to .env and fill in your values.

# Provider: DashScope (Qwen) — https://dashscope.aliyuncs.com/
DASHSCOPE_API_KEY=sk-your-key-here

# Provider: OpenAI — https://platform.openai.com/
# OPENAI_API_KEY=sk-your-key-here

# Optional overrides
# MINIHARNESS_PROFILE=qwen
# MINIHARNESS_MODEL=qwen3-32b
# MINIHARNESS_BASE_URL=
# MINIHARNESS_MAX_TURNS=8
# MINIHARNESS_SANDBOX_ENABLED=false
# MINIHARNESS_SANDBOX_IMAGE=miniharness-sandbox:latest
